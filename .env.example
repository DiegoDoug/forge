# Copy this file to `.env` and fill in the values before running
# `docker compose up --build`.

# Required. The root encryption key for the vault and session signing.
# Generate a strong one with: openssl rand -base64 32
FORGE_MASTER_KEY=

# Port Forge is served on (http://localhost:FORGE_PORT).
FORGE_PORT=8585

# Set to "true" once Forge sits behind HTTPS (a reverse proxy, Tailscale,
# etc). Leave "false" for plain-HTTP LAN/local use — a `Secure` cookie is
# silently dropped by browsers on non-HTTPS origins, which would otherwise
# break login.
FORGE_SESSION_COOKIE_SECURE=false

# --- Optional: vision-LLM assisted Ingest conversion (off by default) ---
# Costs money and requires an API key from an OpenAI-compatible provider.
# FORGE_VISION_ENABLED=1
# FORGE_VISION_API_KEY=
# FORGE_VISION_BASE_URL=
